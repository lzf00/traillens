{
  "name": "traillens-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "api:export": "cd ../.. && python3 scripts/export_openapi.py --out apps/web/lib/api/openapi.json",
    "api:generate": "openapi-typescript lib/api/openapi.json -o lib/api/schema.d.ts",
    "api:sync": "npm run api:export && npm run api:generate"
  },
  "dependencies": {
    "next": "15.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.0.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "ai": "^3.4.0",
    "next-intl": "^3.20.0",
    "posthog-js": "^1.150.0",
    "@sentry/nextjs": "^8.30.0",
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "openapi-typescript": "^7.4.0"
  }
}
