# ============================================================================
# TrailLens 环境变量样例。复制为 .env 后填值;.env 已在 .gitignore 中。
# 字段分组对应 docs/PRODUCT_PLAN.md §4.1 模块责任划分。
# ============================================================================

# ---- 本地基础设施(对应 docker-compose.yml) -----------------------------
POSTGRES_USER=traillens
POSTGRES_PASSWORD=traillens_dev
POSTGRES_DB=traillens
POSTGRES_PORT=5432
DATABASE_URL=postgresql://traillens:traillens_dev@localhost:5432/traillens

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- LLM / VLM 供应商 -------------------------------------------
# 国内默认:豆包(火山引擎,OpenAI 兼容接口)
# 控制台: https://console.volcengine.com/ark
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
# Critic / Story 节点(强推理 + 多模态)
DOUBAO_TEXT_ENDPOINT=ep-xxxxxxxx-yyyyy
# Culling 节点(视觉评分 + 构图判断)
DOUBAO_VISION_ENDPOINT=ep-xxxxxxxx-yyyyy

# DeepSeek(备选,纯文本任务用 deepseek-chat 性价比更高)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic(海外备份,可空)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI(兜底,可空)
OPENAI_API_KEY=

# ---- 美学评分模型(Modal endpoint,§4.1) ---------------------------------
TRAILLENS_AESTHETIC_ENDPOINT=https://your-handle--qalign-landscape.modal.run
TRAILLENS_AESTHETIC_TOKEN=

# ---- 对象存储(R2 / S3 兼容) ---------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=traillens-photos
R2_PUBLIC_BASE=https://photos.traillens.example

# ---- 鉴权(Clerk 或 Better-Auth) -----------------------------------------
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- 计费(Stripe,§5) ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_PLUS=

# ---- 可观测性(§4 Infra) ------------------------------------------------
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_SECRET=please-generate-a-random-string
LANGFUSE_SALT=please-generate-a-random-string
SENTRY_DSN=

# ---- 第三方数据(MCP servers 用) -----------------------------------------
# Open-Meteo 无 key 免费;OWM 仅作 fallback
OPEN_WEATHER_API_KEY=
# Overpass API 默认走公共节点

# ---- 运行配置 -------------------------------------------------------------
TRAILLENS_ENV=local
LOG_LEVEL=info
