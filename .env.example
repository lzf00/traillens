# ============================================================================
# TrailLens 环境变量样例。复制为 .env 后填值;.env 已在 .gitignore 中。
# 字段分组对应 docs/PRODUCT_PLAN.md §4.1 模块责任划分。
# ============================================================================

# ---- 本地基础设施(对应 docker-compose.yml) -----------------------------
POSTGRES_USER=traillens
POSTGRES_PASSWORD=traillens_dev
POSTGRES_DB=traillens
POSTGRES_PORT=5432
DATABASE_URL=postgresql://traillens:traillens_dev@localhost:5432/traillens

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- LLM / VLM 供应商 -------------------------------------------
# 国内默认:豆包(火山引擎方舟 Ark)— 用 Responses API,直接传模型 ID
# 控制台: https://console.volcengine.com/ark
# 文档: https://www.volcengine.com/docs/82379/1399008
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
# 视觉模型(critic / vision 用)
DOUBAO_MODEL_VISION=doubao-seed-2-0-pro-260215
# 文本模型(story 用 — 长上下文 + 强推理)
DOUBAO_MODEL_TEXT=doubao-seed-1-6-thinking-250715

# DeepSeek(备选,纯文本任务用 deepseek-chat 性价比更高)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic(海外备份,可空)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI(兜底,可空)
OPENAI_API_KEY=

# ---- 美学评分模型(Modal endpoint,§4.1) ---------------------------------
TRAILLENS_AESTHETIC_ENDPOINT=https://your-handle--qalign-landscape.modal.run
TRAILLENS_AESTHETIC_TOKEN=

# ---- 对象存储 — 国内默认腾讯云 COS -----------------------------------
# 控制台:https://console.cloud.tencent.com/cos/bucket
# 1. 新建 bucket:名字会自动拼接 APPID,形如 traillens-photos-1305566123
# 2. 拿 API 密钥:https://console.cloud.tencent.com/cam/capi
# 3. 区域选与 CVM 同区(与 110.40.142.199 同区,免内网流量费)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=traillens-photos-1305566123
COS_REGION=ap-shanghai
# 可选:自定义域(填了走自己的域;不填走 cos.<region>.myqcloud.com)
COS_DOMAIN=photos.traillens.zorotreeking.online

# 七牛云 Kodo(国内备选,10GB 永久免费)— 留空跳过
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# Cloudflare R2(海外备选,留空跳过)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# ---- 鉴权(Clerk 或 Better-Auth) -----------------------------------------
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- 计费(Stripe,§5) ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_PLUS=

# ---- 可观测性(§4 Infra) ------------------------------------------------
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_SECRET=please-generate-a-random-string
LANGFUSE_SALT=please-generate-a-random-string
SENTRY_DSN=

# ---- 第三方数据(MCP servers 用) -----------------------------------------
# Open-Meteo 无 key 免费;OWM 仅作 fallback
OPEN_WEATHER_API_KEY=
# Overpass API 默认走公共节点

# ---- 运行配置 -------------------------------------------------------------
TRAILLENS_ENV=local
LOG_LEVEL=info
